# ── MongoDB Atlas ─────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/studyai?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────
JWT_SECRET=your_super_secret_key_min_32_chars_change_this
JWT_REFRESH_SECRET=another_secret_for_refresh_tokens
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ── Server ────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# ── AI (Choose one) ───────────────────────────────
# Option 1: OpenAI
OPENAI_API_KEY=sk-...your_openai_key_here

# Option 2: Google Gemini (Free!)
GEMINI_API_KEY=AIza...your_gemini_key_here

# ── Spotify API ──────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:5000/auth/spotify/callback

# Which AI to use: "openai" or "gemini"
AI_PROVIDER=gemini

# ── Google OAuth (optional) ───────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
